{
  "buildCommand": "node frontend/inject-config.js",
  "outputDirectory": "frontend",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/Login.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
